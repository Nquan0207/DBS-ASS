@model List<CreateSchedule>

<div class = "card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Student List</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <div class="row pb-3">
            <div class="col-6">
                <h2 class="text-primary">Student List</h2>
            </div>

        </div>
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Student Name</th>
                    <th>Mssv</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var obj in Model)
                {
                    <tr>
                        <td class="col-4"> <!-- Adjust column width (larger) -->
                            @obj.Mssv   
                        </td>
                        <td class="col-4"> <!-- Adjust column width (larger) -->
                            @obj.ScheduleID
                        </td>
                        <td class="col-5"> <!-- Adjust column width (smaller) -->
                            <div class="w-75 btn-group" role="group">
                                <a asp-controller="Student" asp-action="Edit" asp-route-ID="@obj.Mssv" class="btn btn-primary mx-2">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <a asp-controller="Student" asp-action="Delete" asp-route-ID="@obj.Mssv" class="btn btn-primary mx-2">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>

                }
            </tbody>
        </table>
    </div>
</div>
